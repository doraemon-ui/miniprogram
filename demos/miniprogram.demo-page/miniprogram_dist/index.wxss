@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
@font-face {
  font-family:"DemoPage iconfont";src:url(data:font/woff2;charset=utf-8;base64,)format("woff2");font-weight:normal;font-style:normal;font-display:swap;
}

.dora-demo-page__iconfont {
  font-family: "DemoPage iconfont"!important;
  font-size: 16px;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.dora-demo-page__iconfont-light::before {
  content: "";
}

.dora-demo-page__iconfont-dark::before {
  content: "";
}

.dora-demo-page {
  position: relative;
  min-height: 100%;
  color: rgba(0,0,0,0.85);
  color: rgba(var(--dora-text-color-rgb),0.85);
  background-color: #fafafa;
  background-color: var(--dora-background-color);
}

.dora-demo-page__hd {
  position: relative;
  padding: 40px;
}

.dora-demo-page__bd {
  padding-bottom: 40px;
}

.dora-demo-page__bd--spacing {
  padding-left: 16px;
  padding-right: 16px;
}

.dora-demo-page__ft {
  padding-bottom: 12px;
  text-align: center;
}

.dora-demo-page__title {
  text-align: left;
  font-size: 20px;
  font-weight: 400;
}

.dora-demo-page__desc {
  margin-top: 6px;
  color: rgba(0,0,0,0.45);
  color: rgba(var(--dora-text-color-rgb),0.45);
  text-align: left;
  font-size: 14px;
}

.dora-demo-page__darkmode {
  position: absolute;
  right: 12px;
  top: 12px;
  width: 24px;
  height: 24px;
  font-size: 24px;
  line-height: 24px;
}
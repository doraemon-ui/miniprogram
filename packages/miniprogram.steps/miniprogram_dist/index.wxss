@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-steps {
  position: relative;
  width: 100%
}
.dora-step {
  font-size: 0;
  position: relative;
  display: inline-block;
  box-sizing: border-box;
  padding: 0 10rpx;
  vertical-align: top
}
.dora-step--vertical {
  padding-bottom: 60rpx
}
.dora-step--vertical .dora-step__hd {
  float: left
}
.dora-step--vertical .dora-step__bd {
  overflow: hidden;
  display: block;
  margin-left: 80rpx;
  margin-top: 0;
  text-align: left;
  clear: inherit
}
.dora-step--vertical .dora-step__ft {
  position: absolute;
  left: 38rpx;
  top: 0;
  height: 100%;
  width: 4rpx;
  padding: 60rpx 0 8rpx;
  margin-left: 0
}
.dora-step--vertical .dora-step__ft::after {
  width: 4rpx;
  height: 100%
}
.dora-step__ft {
  position: absolute;
  left: 50%;
  width: 100%;
  top: 24rpx;
  padding: 0 48rpx;
  margin-left: 6rpx;
  box-sizing: border-box
}
.dora-step__ft::after {
  content: "";
  display: inline-block;
  background: var(--dora-border-color,#ddd);
  background: var(--dora-border-color,#ddd);
  height: 4rpx;
  border-radius: 4rpx;
  width: 100%;
  transition: background .3s;
  position: relative;
  left: -4rpx
}
.dora-step__icon {
  box-sizing: border-box;
  font-size: 48rpx/2;
  line-height: 46rpx;
  width: 48rpx;
  height: 100%;
  border-radius: 50%;
  background: #fff;
  position: relative;
  z-index: 2;
  margin: 0 auto;
  border: #d9d9d9 solid 2rpx
}
.dora-step__thumb {
  width: 100%;
  height: 100%;
  display: inline-block;
  overflow: hidden
}
.dora-step--process .dora-step__icon {
  border: #33cd5f solid 2rpx;
  color: #fff;
  background: #33cd5f
}
.dora-step--wait .dora-step__icon {
  border: #d9d9d9 solid 2rpx;
  color: #d9d9d9
}
.dora-step--wait .dora-step__ft::after {
  background: #d9d9d9
}
.dora-step--finish .dora-step__icon {
  border: #33cd5f solid 2rpx;
  color: #33cd5f
}
.dora-step--finish .dora-step__ft::after {
  background: #33cd5f
}
.dora-step--error .dora-step__icon {
  border: #ef473a solid 2rpx;
  color: #ef473a
}
.dora-step--error .dora-step__ft::after {
  background: #ef473a
}
.dora-step__hd {
  width: auto;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box
}
.dora-step__bd {
  margin-top: 20rpx;
  text-align: center;
  clear: both
}
.dora-step__title {
  font-size: var(--dora-font-size-lg,32rpx);
  font-size: var(--dora-font-size-lg,32rpx);
  font-weight: 700;
  color: var(--dora-color-title,#333);
  color: var(--dora-color-title,#333)
}
.dora-step__content {
  font-size: var(--dora-font-size-sm,24rpx);
  font-size: var(--dora-font-size-sm,24rpx);
  margin-top: 6rpx;
  color: var(--dora-color-text-base,#666);
  color: var(--dora-color-text-base,#666)
}
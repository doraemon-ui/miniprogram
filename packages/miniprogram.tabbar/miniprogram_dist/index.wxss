@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-tabbar {
  position: relative;
  z-index: 500;
  width: 100%;
  background-color: #fff;
  box-sizing: border-box
}
.dora-tabbar-wrap {
  width: 100%;
  min-height: 98rpx;
  box-sizing: border-box;
  display: -ms-flexbox;
  display: flex
}
.dora-tabbar--bottom {
  position: fixed;
  left: 0;
  bottom: 0;
  border-top: 1rpx solid var(--dora-border-color-split,var(--dora-color-step-15,#d9d9d9));
  border-top: 1rpx solid var(--dora-border-color-split,var(--dora-color-step-15,#d9d9d9))
}
.dora-tabbar--top {
  position: fixed;
  left: 0;
  top: 0;
  border-bottom: 1rpx solid var(--dora-border-color-split,var(--dora-color-step-15,#d9d9d9));
  border-bottom: 1rpx solid var(--dora-border-color-split,var(--dora-color-step-15,#d9d9d9))
}
.dora-tabbar-item {
  -ms-flex: 1;
  flex: 1;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-pack: center;
  justify-content: center;
  -ms-flex-align: center;
  align-items: center;
  -ms-flex-direction: column;
  flex-direction: column;
  text-align: center;
  width: 100%;
  height: 100%;
  color: #666;
  padding: 10rpx 0;
  box-sizing: border-box;
  float: left;
  cursor: pointer
}
.dora-tabbar-item__icon {
  display: -ms-flexbox;
  display: flex;
  -ms-flex-pack: center;
  justify-content: center;
  font-size: 44rpx;
  height: 44rpx;
  line-height: 1
}
.dora-tabbar-item__title {
  font-size: 24rpx;
  margin: 4rpx 0 0;
  line-height: 1;
  text-align: center
}
.dora-tabbar-item--current {
  color: #33cd5f
}
.dora-tabbar-item--disabled {
  opacity: var(--dora-disabled-opacity,.3);
  opacity: var(--dora-disabled-opacity,.3);
  cursor: not-allowed
}
.dora-tabbar-item--light.dora-tabbar-item--current {
  color: #ddd
}
.dora-tabbar-item--stable.dora-tabbar-item--current {
  color: #b2b2b2
}
.dora-tabbar-item--positive.dora-tabbar-item--current {
  color: #387ef5
}
.dora-tabbar-item--calm.dora-tabbar-item--current {
  color: #11c1f3
}
.dora-tabbar-item--assertive.dora-tabbar-item--current {
  color: #ef473a
}
.dora-tabbar-item--balanced.dora-tabbar-item--current {
  color: #33cd5f
}
.dora-tabbar-item--energized.dora-tabbar-item--current {
  color: #ffc900
}
.dora-tabbar-item--royal.dora-tabbar-item--current {
  color: #886aea
}
.dora-tabbar-item--dark.dora-tabbar-item--current {
  color: #444
}
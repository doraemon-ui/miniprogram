@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
.dora-toast {
  --text-color: var(--dora-toast-text-color, #fff);
  --background-color: var(--dora-toast-background-color, rgba(0, 0, 0, 0.7));
  --border-radius: var(--dora-toast-border-radius, var(--dora-border-radius, 8px));
  --min-width: var(--dora-toast-min-width, 96px);
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--background-color);
  background-color: var(--background-color);
  font-size: 14px;
  line-height: 1.5;
  word-break: break-all;
  min-width: var(--min-width);
  min-width: var(--min-width);
  width: -moz-fit-content;
  width: fit-content;
  border-radius: var(--border-radius);
  border-radius: var(--border-radius);
  color: var(--text-color);
  color: var(--text-color);
}

.dora-toast__content {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 12px;
  padding-bottom: 12px;
  padding-left: 12px;
  padding-right: 12px;
}

.dora-toast__content--has-icon {
  padding-top: 16px;
  padding-bottom: 16px;
  padding-left: 32px;
  padding-right: 32px;
}

.dora-toast__content--has-icon .dora-toast__text {
  margin-top: 9px;
  margin-bottom: unset;
}

.dora-toast__icon {
  margin: 0;
  display: inline-block;
}

.dora-toast__icon--loading {
  animation: loadingCircle 1s infinite linear;
}

.dora-toast__img {
  width: 48px;
  height: auto;
}

@keyframes loadingCircle {
  to {
    transform: rotate(360deg);
  }
}
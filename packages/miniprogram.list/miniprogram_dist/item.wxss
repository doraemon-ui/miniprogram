@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
.dora-list-item {
  padding: 0;
  margin: 0;
  border-radius: 0;
  color: inherit!important;
  background: transparent!important;
  font-size: inherit;
  font-weight: normal;
  line-height: inherit;
  text-align: inherit;
  text-decoration: none;
  overflow: visible;
  min-height: 0!important;
  width: auto!important;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
  padding: 16px;
  position: relative;
  display: flex;
  align-items: center;
  background: var(--dora-component-background-color, #fff);
  background: var(--dora-component-background-color, #fff);
}

.dora-list-item::after {
  display: block;
  position: static;
  top: auto;
  left: auto;
  width: auto;
  height: auto;
  border: none;
  border-radius: 0;
  transform: none;
  transform-origin: 0 0;
}

.dora-list-item--align-flex-start {
  align-items: flex-start;
}

.dora-list-item--align-center {
  align-items: center;
}

.dora-list-item--has-line.dora-list-item::after {
  content: " ";
  position: absolute;
  left: 0;
  bottom: 0;
  right: 0;
  height: 1px;
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  transform-origin: 0 100%;
  transform: scaleY(0.5);
  left: 16px;
}

.dora-list-item--has-line.dora-list-item--last::after {
  display: none;
}

.dora-list-item--hover {
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6))!important;
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6))!important;
}

.dora-list-item--disabled {
  opacity: var(--dora-disabled-opacity, 0.3);
  opacity: var(--dora-disabled-opacity, 0.3);
}

.dora-list-item__hd:not(:empty) {
  width: var(--header-width);
  width: var(--header-width);
  flex: none;
  margin-right: 6px;
}

.dora-list-item__thumb {
  width: var(--thumb-size);
  width: var(--thumb-size);
  height: var(--thumb-size);
  height: var(--thumb-size);
  display: block;
}

.dora-list-item__bd {
  flex: 1;
}

.dora-list-item__title:not(:empty) {
  text-align: left;
}

.dora-list-item__description:not(:empty) {
  text-align: left;
  line-height: 1.2;
  font-size: 12px;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
}

.dora-list-item__ft {
  display: flex;
  align-self: center;
  text-align: right;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
}

.dora-list-item__arrow:not(:empty) {
  flex: none;
  display: flex;
  align-items: center;
  margin-left: 6px;
}

.dora-list-item--access>.dora-list-item__ft {
  padding-right: 22px;
  position: relative;
}

.dora-list-item--access>.dora-list-item__ft::after {
  content: " ";
  display: inline-block;
  width: 16px;
  height: 16px;
  background-image: url(data:image/svg+xml;charset=utf-8,%3Csvg%20width%3D%2216%22%20height%3D%2226%22%20viewBox%3D%220%200%2016%2026%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M2%200L0%202l11.5%2011L0%2024l2%202%2014-13z%22%20fill%3D%22%23c7c7cc%22%20fill-rule%3D%22evenodd%22%2F%3E%3C%2Fsvg%3E);
  background-size: contain;
  background-repeat: no-repeat;
  background-position: 50% 50%;
  transform: rotate(0);
  transform: rotate(0) translateY(-50%);
  position: absolute;
  top: 50%;
  right: 0;
}
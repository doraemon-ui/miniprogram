@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
.dora-tag {
  display: inline-flex;
  align-items: center;
  line-height: 40rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: var(--dora-border-radius, 8px);
  border-radius: var(--dora-border-radius, 8px);
  border: 2rpx solid var(--dora-border-color, var(--dora-color-step-10, #e6e6e6));
  border: 2rpx solid var(--dora-border-color, var(--dora-color-step-10, #e6e6e6));
  background: #fafafa;
  font-size: 14px;
  margin-right: 16rpx;
  white-space: nowrap;
}

.dora-tag--hover {
  opacity: 0.85;
}

.dora-tag__icon {
  margin-left: 8rpx;
}

.dora-tag--magenta {
  color: #eb2f96;
  background: rgba(235,47,150,0.06);
  border-color: rgba(235,47,150,0.3);
}

.dora-tag--red {
  color: #f5222d;
  background: rgba(245,34,45,0.06);
  border-color: rgba(245,34,45,0.3);
}

.dora-tag--volcano {
  color: #fa541c;
  background: rgba(250,84,28,0.06);
  border-color: rgba(250,84,28,0.3);
}

.dora-tag--orange {
  color: #fa8c16;
  background: rgba(250,140,22,0.06);
  border-color: rgba(250,140,22,0.3);
}

.dora-tag--gold {
  color: #faad14;
  background: rgba(250,173,20,0.06);
  border-color: rgba(250,173,20,0.3);
}

.dora-tag--lime {
  color: #a0d911;
  background: rgba(160,217,17,0.06);
  border-color: rgba(160,217,17,0.3);
}

.dora-tag--green {
  color: #52c41a;
  background: rgba(82,196,26,0.06);
  border-color: rgba(82,196,26,0.3);
}

.dora-tag--cyan {
  color: #13c2c2;
  background: rgba(19,194,194,0.06);
  border-color: rgba(19,194,194,0.3);
}

.dora-tag--blue {
  color: #1890ff;
  background: rgba(24,144,255,0.06);
  border-color: rgba(24,144,255,0.3);
}

.dora-tag--geekblue {
  color: #2f54eb;
  background: rgba(47,84,235,0.06);
  border-color: rgba(47,84,235,0.3);
}

.dora-tag--purple {
  color: #722ed1;
  background: rgba(114,46,209,0.06);
  border-color: rgba(114,46,209,0.3);
}
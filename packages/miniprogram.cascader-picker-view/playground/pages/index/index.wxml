<demo-page title="CascaderPickerView" desc="级联选择器" spacing>
  <demo-block title="Default">
    <dora-cascader-picker-view value="{{ value1 }}" options="{{ options }}" bind:valueChange="onValueChange1" />
  </demo-block>
  <demo-block title="Multiple & cols = 2">
    <dora-cascader-picker-view value="{{ value2 }}" options="{{ options }}" cols="{{ 2 }}" bind:valueChange="onValueChange2" />
  </demo-block>
  <demo-block title="Multiple & loading">
    <dora-cascader-picker-view value="{{ value3 }}" options="{{ province }}" cols="{{ 1 }}" loading="{{ loading }}" bind:valueChange="onValueChange3" />
  </demo-block>
  <demo-block title="Custom FieldName">
    <dora-cascader-picker-view options="{{ fieldNamesOptions }}" defaultFieldNames="{{ fieldNames }}" />
  </demo-block>
  <demo-block title="Custom Image">
    <dora-cascader-picker-view options="{{ imageOptions }}" />
  </demo-block>
</demo-page>
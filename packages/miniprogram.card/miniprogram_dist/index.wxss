@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
.dora-card {
  position: relative;
  min-height: var(--dora-card-height, 96px);
  min-height: var(--dora-card-height, 96px);
  padding-bottom: 6px;
  display: flex;
  flex-direction: column;
  background-color: var(--dora-card-background-color, var(--dora-component-background-color, #fff));
  background-color: var(--dora-card-background-color, var(--dora-component-background-color, #fff));
}

.dora-card--hover {
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6));
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6));
}

.dora-card--bordered {
  border-radius: var(--dora-card-radius, 10px);
  border-radius: var(--dora-card-radius, 10px);
}

.dora-card--bordered::before {
  content: " ";
  position: absolute;
  top: 0;
  left: 0;
  width: 200%;
  height: 200%;
  transform: scale(0.5);
  transform-origin: 0 0;
  pointer-events: none;
  box-sizing: border-box;
  border: 0 solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border: 0 solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-radius: var(--dora-card-radius, 10px);
  border-radius: var(--dora-card-radius, 10px);
  border-top-width: var(--dora-border-width, 1px);
  border-top-width: var(--dora-border-width, 1px);
  border-right-width: var(--dora-border-width, 1px);
  border-right-width: var(--dora-border-width, 1px);
  border-bottom-width: var(--dora-border-width, 1px);
  border-bottom-width: var(--dora-border-width, 1px);
  border-left-width: var(--dora-border-width, 1px);
  border-left-width: var(--dora-border-width, 1px);
}

.dora-card--full {
  border-radius: 0;
}

.dora-card--full::before {
  border-radius: 0;
  border-right-width: 0;
  border-left-width: 0;
}

.dora-card--has-actions {
  padding-bottom: 0;
}

.dora-card__hd {
  position: relative;
  display: flex;
  font-size: 17px;
  padding: var(--dora-card-hd-padding, 9px 12px);
  padding: var(--dora-card-hd-padding, 9px 12px);
  align-items: center;
}

.dora-card__hd::before {
  content: " ";
  position: absolute;
  left: 0;
  bottom: 0;
  right: 0;
  height: 1px;
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  transform-origin: 0 100%;
  transform: scaleY(0.5);
}

.dora-card__content {
  flex: 1;
  text-align: left;
  color: var(--dora-black, #000);
  color: var(--dora-black, #000);
}

.dora-card__thumb {
  width: var(--dora-card-icon-size, 32px);
  width: var(--dora-card-icon-size, 32px);
  height: var(--dora-card-icon-size, 32px);
  height: var(--dora-card-icon-size, 32px);
  display: inline-block;
  position: relative;
  margin-left: auto;
  margin-right: 6px;
  overflow: hidden;
  vertical-align: middle;
}

.dora-card__extra {
  flex: 1;
  text-align: right;
  font-size: 17px;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
}

.dora-card__bd {
  position: relative;
  padding: var(--dora-card-bd-padding, 12px 12px 6px);
  padding: var(--dora-card-bd-padding, 12px 12px 6px);
  font-size: 15px;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.55);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.55);
  min-height: 40px;
}

.dora-card__ft {
  display: flex;
  font-size: 14px;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
  padding: var(--dora-card-ft-padding, 0 12px);
  padding: var(--dora-card-ft-padding, 0 12px);
}

.dora-card__actions {
  position: relative;
  display: flex;
  line-height: 50px;
  margin-top: 6px;
  justify-content: center;
  align-items: center;
}

.dora-card__actions::before {
  content: " ";
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 1px;
  border-top: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-top: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  transform-origin: 0 0;
  transform: scaleY(0.5);
}

.dora-card__action {
  position: relative;
  display: block;
  flex: 1;
  color: var(--dora-color-balanced, #2dd36f);
  color: var(--dora-color-balanced, #2dd36f);
  text-align: center;
}

.dora-card__action::before {
  content: " ";
  position: absolute;
  right: 0;
  top: 0;
  width: 1px;
  bottom: 0;
  border-right: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-right: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  transform-origin: 100%0;
  transform: scaleX(0.5);
}

.dora-card__action:last-child::before {
  display: none;
}

.dora-card__action--default {
  color: var(--dora-color-dark, #222428)!important;
  color: var(--dora-color-dark, #222428)!important;
}

.dora-card__action--primary {
  color: var(--dora-color-balanced, #2dd36f)!important;
  color: var(--dora-color-balanced, #2dd36f)!important;
}

.dora-card__action--light {
  color: var(--dora-color-light, #f4f5f8)!important;
  color: var(--dora-color-light, #f4f5f8)!important;
}

.dora-card__action--stable {
  color: var(--dora-color-stable, #92949c)!important;
  color: var(--dora-color-stable, #92949c)!important;
}

.dora-card__action--positive {
  color: var(--dora-color-positive, #3880ff)!important;
  color: var(--dora-color-positive, #3880ff)!important;
}

.dora-card__action--calm {
  color: var(--dora-color-calm, #3dc2ff)!important;
  color: var(--dora-color-calm, #3dc2ff)!important;
}

.dora-card__action--assertive {
  color: var(--dora-color-assertive, #eb445a)!important;
  color: var(--dora-color-assertive, #eb445a)!important;
}

.dora-card__action--balanced {
  color: var(--dora-color-balanced, #2dd36f)!important;
  color: var(--dora-color-balanced, #2dd36f)!important;
}

.dora-card__action--energized {
  color: var(--dora-color-energized, #ffc409)!important;
  color: var(--dora-color-energized, #ffc409)!important;
}

.dora-card__action--royal {
  color: var(--dora-color-royal, #8a63d2)!important;
  color: var(--dora-color-royal, #8a63d2)!important;
}

.dora-card__action--dark {
  color: var(--dora-color-dark, #222428)!important;
  color: var(--dora-color-dark, #222428)!important;
}

.dora-card__action--bold {
  font-weight: 500!important;
}

.dora-card__action--hover {
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6))!important;
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6))!important;
}

.dora-card__action--disabled {
  opacity: var(--dora-disabled-opacity, 0.3);
  opacity: var(--dora-disabled-opacity, 0.3);
  cursor: not-allowed;
}
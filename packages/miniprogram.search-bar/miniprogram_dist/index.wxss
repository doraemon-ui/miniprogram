@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-search-bar {
  position: relative;
  padding: 16rpx 20rpx;
  display: -ms-flexbox;
  display: flex;
  box-sizing: border-box;
  background-color: #efeff4;
  border-top: 1rpx solid var(--dora-border-color,#ddd);
  border-top: 1rpx solid var(--dora-border-color,#ddd);
  border-bottom: 1rpx solid var(--dora-border-color,#ddd);
  border-bottom: 1rpx solid var(--dora-border-color,#ddd)
}
.dora-search-bar__form {
  position: relative;
  -ms-flex: 1;
  flex: 1;
  width: 100%;
  height: 56rpx;
  overflow: hidden;
  background-color: #fff;
  background-clip: padding-box;
  border-radius: 12rpx
}
.dora-search-bar__box {
  position: relative;
  padding-left: 60rpx;
  padding-right: 60rpx;
  height: 100%;
  width: 100%;
  box-sizing: border-box;
  z-index: 1
}
.dora-search-bar__control {
  height: 56rpx;
  padding: 8rpx 0;
  box-sizing: border-box
}
.dora-search-bar__input {
  width: 100%;
  height: 100%;
  min-height: inherit;
  border: 0;
  font-size: 28rpx;
  line-height: 1;
  color: var(--dora-color-text-base,#333);
  color: var(--dora-color-text-base,#333);
  text-align: left;
  background: 0 0;
  box-sizing: border-box
}
.dora-search-bar__label {
  display: -ms-flexbox;
  display: flex;
  -ms-flex-pack: center;
  justify-content: center;
  -ms-flex-align: center;
  align-items: center;
  position: absolute;
  top: 1rpx;
  right: 1rpx;
  bottom: 1rpx;
  left: 1rpx;
  z-index: 2;
  border-radius: 12rpx;
  text-align: center;
  color: var(--dora-color-text-secondary,#999);
  color: var(--dora-color-text-secondary,#999);
  background: #fff
}
.dora-search-bar__text {
  display: inline-block;
  font-size: 28rpx;
  vertical-align: middle;
  margin-left: 16rpx
}
.dora-search-bar__cancel {
  margin-left: 20rpx;
  line-height: 56rpx;
  color: var(--dora-color-primary,#33cd5f);
  color: var(--dora-color-primary,#33cd5f);
  white-space: nowrap
}
.dora-search-bar__icon {
  vertical-align: middle
}
.dora-search-bar__search {
  position: absolute;
  left: 20rpx;
  top: 14rpx
}
.dora-search-bar__clear {
  display: block;
  position: absolute;
  top: 14rpx;
  right: 0;
  padding: 0 20rpx
}
.dora-search-bar--disabled {
  opacity: .45
}
@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
.dora-field {
  padding: 24rpx 32rpx;
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
}

.dora-field__child {
  display: flex;
}

.dora-field__child--position-right {
  justify-content: flex-end;
}

.dora-field__child--position-normal {
  justify-content: normal;
}

.dora-field__label {
  position: relative;
  margin-left: 0;
  margin-bottom: 0;
  margin-right: 6px;
  text-align: left;
  white-space: nowrap;
  width: 210rpx;
}

.dora-field__label--wrap {
  white-space: normal;
}

.dora-field__label-help {
  margin-left: 6px;
}

.dora-field__feedback-message {
  color: var(--dora-color-assertive, #eb445a);
  color: var(--dora-color-assertive, #eb445a);
  margin-top: 6px;
}

.dora-field__required-asterisk {
  display: inline-block;
  position: absolute;
  left: -0.6em;
  top: 0;
  color: var(--dora-color-assertive, #eb445a);
  color: var(--dora-color-assertive, #eb445a);
}

.dora-field__required-text {
  display: inline-block;
  margin-left: 6px;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.45);
}

.dora-field__arrow {
  display: flex;
}

.hidden {
  display: none!important;
}

.disabled,.readOnly {
  cursor: not-allowed!important;
  pointer-events: none!important;
}
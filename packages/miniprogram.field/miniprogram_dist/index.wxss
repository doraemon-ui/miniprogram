@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-field {
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid var(--dora-border-color-split,var(--dora-color-step-15,#d9d9d9));
  border-bottom: 2rpx solid var(--dora-border-color-split,var(--dora-color-step-15,#d9d9d9))
}
.dora-field__child {
  display: -ms-flexbox;
  display: flex
}
.dora-field__child--position-right {
  -ms-flex-pack: end;
  justify-content: flex-end
}
.dora-field__child--position-normal {
  -ms-flex-pack: normal;
  justify-content: normal
}
.dora-field__label {
  position: relative;
  margin-left: 0;
  margin-bottom: 0;
  margin-right: 12rpx;
  text-align: left;
  white-space: nowrap;
  width: 210rpx
}
.dora-field__label--wrap {
  white-space: normal
}
.dora-field__label-help {
  margin-left: 12rpx
}
.dora-field__feedback-message {
  color: var(--dora-color-assertive,#eb445a);
  color: var(--dora-color-assertive,#eb445a);
  margin-top: 12rpx
}
.dora-field__required-asterisk {
  display: inline-block;
  position: absolute;
  left: -.6em;
  top: 0;
  color: var(--dora-color-assertive,#eb445a);
  color: var(--dora-color-assertive,#eb445a)
}
.dora-field__required-text {
  display: inline-block;
  margin-left: 12rpx;
  color: rgba(var(--dora-text-color-rgb,0,0,0),.45);
  color: rgba(var(--dora-text-color-rgb,0,0,0),.45)
}
.dora-field__arrow {
  display: -ms-flexbox;
  display: flex
}
.hidden {
  display: none!important
}
.disabled,
.readOnly {
  cursor: not-allowed!important;
  pointer-events: none!important
}
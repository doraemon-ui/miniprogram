@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-loading {
  position: fixed;
  z-index: var(--dora-z-index-toast,1080);
  z-index: var(--dora-z-index-toast,1080);
  top: 50%;
  left: 50%;
  background: var(--dora-loading-bg,rgba(58,58,58,.95));
  background: var(--dora-loading-bg,rgba(58,58,58,.95));
  font-size: var(--dora-font-size-md,28rpx);
  font-size: var(--dora-font-size-md,28rpx);
  line-height: var(--dora-line-height-md,1.5);
  line-height: var(--dora-line-height-md,1.5);
  text-align: center;
  border-radius: var(--dora-border-radius,16rpx);
  border-radius: var(--dora-border-radius,16rpx);
  color: var(--dora-white,#fff);
  color: var(--dora-white,#fff);
  transform: translate3d(-50%,-50%,0)
}
.dora-loading__content {
  min-width: 236rpx;
  padding: 18rpx 30rpx;
  box-sizing: border-box
}
.dora-loading__content--has-icon {
  padding: 30rpx
}
.dora-loading__content--has-icon .dora-loading__text {
  margin-top: 12rpx
}
.dora-loading__icon {
  margin: 0;
  display: block
}
.dora-loading__icon--loading {
  display: inline-block!important;
  vertical-align: middle;

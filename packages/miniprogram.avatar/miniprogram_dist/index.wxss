  background-color: var(--dora-component-background-color, #fff);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.65);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.65);
  white-space: nowrap;
  position: relative;
  overflow: hidden;
  vertical-align: middle;
  width: var(--container-size);
  width: var(--container-size);
  height: var(--container-size);
  height: var(--container-size);
  line-height: var(--container-size);
  line-height: var(--container-size);
  font-size: var(--font-size);
  font-size: var(--font-size);

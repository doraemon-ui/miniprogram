<view class="dora-class {{ classes.wrap }}">
  <slot></slot>
  <view class="{{ classes.status }}" wx:if="{{ status }}">
    <view class="{{ classes.statusDot }}"></view>
    <view class="{{ classes.statusText }}" wx:if="{{ text }}">{{ text }}</view>
  </view>
  <view class="{{ classes.count }} dora-class-badge" style="{{ badgeStyle }}" wx:elif="{{ title }}">{{ title }}</view>
  <view class="{{ classes.dot }} dora-class-badge" style="{{ badgeStyle }}" wx:elif="{{ dot }}"></view>
  <view class="{{ classes.count }} dora-class-badge" style="{{ badgeStyle }}" wx:elif="{{ showZero && count === 0 }}">{{ finalCount }}</view>
  <view class="{{ classes.count }} dora-class-badge" style="{{ badgeStyle }}" wx:elif="{{ count !== 0 }}">{{ finalCount }}</view>
</view>
@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
.dora-pagination {
  display: block;
  width: 100%;
  height: 48px;
  overflow: hidden;
  box-sizing: border-box;
  position: relative;
}

.dora-pagination__prev {
  position: absolute;
  left: 10px;
  top: 0;
}

.dora-pagination__next {
  position: absolute;
  right: 10px;
  top: 0;
}

.dora-pagination__number {
  width: 100%;
  height: 48px;
  line-height: 48px;
  margin: 0 auto;
  text-align: center;
}

.dora-pagination__active {
  display: inline;
  color: var(--dora-color-positive, #3880ff);
  color: var(--dora-color-positive, #3880ff);
}

.dora-pagination__pointer {
  width: 100%;
  height: 48px;
  line-height: 48px;
  margin: 0 auto;
  text-align: center;
}

.dora-pagination__dot {
  width: 8px;
  height: 8px;
  display: inline-block;
  margin: 0 3px;
  border-radius: 50%;
  background: var(--dora-color-step-20, #cccccc);
  background: var(--dora-color-step-20, #cccccc);
}

.dora-pagination__dot--active {
  background: var(--dora-color-step-45, #8c8c8c);
  background: var(--dora-color-step-45, #8c8c8c);
}

.dora-pagination__button {
  display: inline-block;
  margin: 0;
}
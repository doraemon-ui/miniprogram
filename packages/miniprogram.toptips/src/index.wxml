<dora-animation-group dora-class="{{ classes.wrap }}" in="{{ in }}" classNames="{{ classNames }}">
  <view class="{{ classes.content }}">
    <dora-icon wx:if="{{ icon && !hidden }}" dora-class="{{ classes.icon }}" type="{{ icon }}" size="21" color="#fff" />
    <text class="{{ classes.text }}">{{ text }}</text>
  </view>
</dora-animation-group>
exports[`Select mount correctly 1`] = `
<dora-select>
  <dora-popup-select
    id="dora-popup-select"
    bind:cancel="onCancel"
    bind:change="onVisibleChange"
    bind:confirm="onConfirm"
    bind:valueChange="onValueChange"
  >
    <dora-popup
      bind:close="close"
      bind:closed="onClosed"
      bind:show="onShow"
    >
      <wx-view
        class="dora-class dora-popup dora-popup--position-bottom"
        style="touch-action: none;  "
        bind:touchend="onTouchEnd"
        bind:touchmove="onTouchMove"
        bind:touchstart="onTouchStart"
      >
        <dora-backdrop
          id="dora-backdrop"
          bind:click="onMaskClick"
        >
          <dora-animation-group
            doraClass="dora-backdrop"
            id="dora-animation-group"
            bind:click="onClick"
            bind:enter="onShow"
            bind:entered="onShowed"
            bind:exited="onClosed"
          />
        </dora-backdrop>
        <dora-animation-group
          doraClass="dora-popup__body"
          id="dora-animation-group"
          bind:enter="onShow"
          bind:entered="onShowed"
          bind:exited="onClosed"
        />
      </wx-view>
    </dora-popup>
    <wx-view
      catch:tap="onTrigger"
    />
  </dora-popup-select>
</dora-select>
`;

exports[`Select mount correctly 1`] = `
<dora-select>
  <dora-popup-select
    id="dora-popup-select"
    bind:cancel="onCancel"
    bind:change="onVisibleChange"
    bind:confirm="onConfirm"
    bind:valueChange="onValueChange"
  >
    <dora-popup
      bind:close="close"
      bind:closed="onClosed"
      bind:show="onShow"
    >
      <wx-view
        class="dora-class dora-popup dora-popup--position-bottom"
        style="touch-action: none;  "
        bind:touchend="onTouchEnd"
        bind:touchmove="onTouchMove"
        bind:touchstart="onTouchStart"
      >
        <dora-backdrop
          disableScroll="{{true}}"
          id="dora-backdrop"
          transparent="{{false}}"
          wrapStyle="{{null}}"
          zIndex="{{null}}"
          bind:click="onMaskClick"
        />
        <dora-animation-group
          classNames="dora-animate--slideInUp"
          doraClass="dora-popup__body"
          id="dora-animation-group"
          in="{{false}}"
          mountOnEnter="{{true}}"
          unmountOnExit="{{true}}"
          wrapStyle="{{Object {}}}"
          bind:enter="onShow"
          bind:entered="onShowed"
          bind:exited="onClosed"
        >
          <wx-view
            class="dora-class dora-select"
          >
            <wx-view
              class="dora-select__toolbar"
              catch:touchmove="noop"
            >
              <wx-view
                class="dora-select__toolbar-inner"
              >
                <wx-view
                  class="dora-select__cancel"
                  hoverClass="dora-select__hover"
                  bind:tap="onCancel"
                >
                  取消
                </wx-view>
                <wx-view
                  class="dora-select__title"
                >
                  请选择
                </wx-view>
                <wx-view
                  class="dora-select__confirm"
                  hoverClass="dora-select__hover"
                  bind:tap="onConfirm"
                >
                  确定
                </wx-view>
              </wx-view>
            </wx-view>
            <wx-scroll-view
              class="dora-select__list"
              scrollY="{{true}}"
            />
            <wx-view
              class="dora-select__prompt"
            >
              <dora-prompt
                icon=""
                text="暂无数据"
                title=""
                visible="{{true}}"
              >
                <wx-view
                  class="dora-class dora-prompt"
                  hoverClass="dora-hover-class dora-prompt--hover"
                  style="background-color: unset;  "
                  bind:tap="onClick"
                />
              </dora-prompt>
            </wx-view>
          </wx-view>
          <dora-safe-area
            safeArea="bottom"
          />
        </dora-animation-group>
      </wx-view>
    </dora-popup>
    <wx-view
      catch:tap="onTrigger"
    />
  </dora-popup-select>
</dora-select>
`;

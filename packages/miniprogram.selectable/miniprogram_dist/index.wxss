@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-selectable {
  position: relative;
  display: inline-block;
  cursor: pointer
}
.dora-selectable__input {
  position: absolute;
  top: 0;
  left: 0;
  opacity: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  border: 0 none;
  -moz-appearance: none;
  appearance: none
}
.dora-selectable__icon {
  display: inline-block;
  font-size: 0;
  vertical-align: middle;
  position: relative;
  top: 0;
  left: 0;
  margin-left: 12rpx;
  margin-right: 12rpx
}
@import '../../@doraemon-ui/style/var.wxss';
@import '../../@doraemon-ui/style/color.wxss';
.dora-cascader {
  width: 100%;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  font-size: var(--dora-cascader-font-size, 14px);
  font-size: var(--dora-cascader-font-size, 14px);
  line-height: 1.5;
  color: var(--dora-cascader-color, rgba(var(--dora-text-color-rgb, 0, 0, 0), 0.55));
  color: var(--dora-cascader-color, rgba(var(--dora-text-color-rgb, 0, 0, 0), 0.55));
}

.dora-cascader__hd {
  position: relative;
  flex: none;
  width: 100%;
}

.dora-cascader__hd::after {
  content: " ";
  position: absolute;
  left: 0;
  bottom: 0;
  right: 0;
  height: 1px;
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-bottom: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  transform-origin: 0 100%;
  transform: scaleY(0.5);
}

.dora-cascader__bd {
  position: relative;
  flex: auto;
  width: 100%;
  height: 100%;
}

.dora-cascader__toolbar {
  position: relative;
  width: 100%;
  font-size: 17px;
  line-height: 1.5;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.55);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.55);
  background-color: var(--dora-cascader-toolbar-bg, #f7f7f8);
  background-color: var(--dora-cascader-toolbar-bg, #f7f7f8);
}

.dora-cascader__toolbar::before {
  content: " ";
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 1px;
  border-top: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  border-top: 1px solid var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  color: var(--dora-border-color-split, var(--dora-color-step-15, #d9d9d9));
  transform-origin: 0 0;
  transform: scaleY(0.5);
}

.dora-cascader__inner {
  height: 44px;
  display: flex;
  text-align: center;
}

.dora-cascader__title {
  position: absolute;
  display: block;
  width: 100%;
  padding: 0;
  font-size: 17px;
  font-weight: normal;
  line-height: 44px;
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.55);
  color: rgba(var(--dora-text-color-rgb, 0, 0, 0),0.55);
  text-align: center;
  white-space: nowrap;
}

.dora-cascader__button {
  position: absolute;
  box-sizing: border-box;
  height: 44px;
  line-height: 44px;
  padding: 0 15px;
  z-index: 10;
}

.dora-cascader__button--cancel {
  left: 0;
  color: var(--dora-color-stable, #92949c);
  color: var(--dora-color-stable, #92949c);
}

.dora-cascader__button--confirm {
  right: 0;
  color: var(--dora-color-balanced, #2dd36f);
  color: var(--dora-color-balanced, #2dd36f);
}

.dora-cascader__button--hover {
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6));
  background-color: var(--dora-active-state-bg, var(--dora-color-step-10, #e6e6e6));
}

.dora-cascader__button--disabled {
  opacity: var(--dora-disabled-opacity, 0.3);
  opacity: var(--dora-disabled-opacity, 0.3);
}
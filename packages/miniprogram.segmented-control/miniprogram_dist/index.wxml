<view class="dora-class {{ classes.wrap }}" wx:if="{{ values.length }}">
  <block wx:for="{{ values }}" wx:key="index" wx:for-item="item">
    <view class="{{ classes.item }} {{ activeKey === index ? prefixCls + '__item--current' : '' }}" data-index="{{ index }}" bindtap="onTap">{{ item }}</view>
  </block>
</view>
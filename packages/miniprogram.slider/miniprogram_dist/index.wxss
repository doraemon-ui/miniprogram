@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-slider {
  position: relative;
  z-index: 1;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-align: center;
  align-items: center
}
.dora-slider__rail-wrap {
  position: relative;
  -ms-flex: 1;
  flex: 1;
  width: 100%;
  padding: 28rpx 0
}
.dora-slider__rail {
  width: 100%;
  height: 8rpx;
  background-color: #e8e8e8;
  border-radius: 999rpx;
  vertical-align: middle;
  position: relative
}
.dora-slider__track {
  position: absolute;
  left: 0;
  height: 8rpx;
  border-radius: 999rpx;
  background-color: #33cd5f
}
.dora-slider__handle {
  background-color: #fff;
  border-radius: 50%;
  height: 32rpx;
  left: 0;
  top: 50%;
  position: absolute;
  width: 32rpx;
  box-shadow: 0 0 8rpx rgba(0,0,0,.2);
  transform: translate3d(-50%,-50%,0);
  transition: transform .2s
}
.dora-slider__handle::after {
  content: attr(data-meta);
  color: #fff;
  position: absolute;
  pointer-events: none;
  display: none;
  opacity: 0;
  visibility: hidden;
  z-index: 15;
  font-size: 24rpx;
  line-height: 1.25;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background-color: rgba(0,0,0,.7);
  white-space: nowrap;
  text-align: center;
  left: 50%;
  bottom: 100%;
  margin-bottom: 20rpx;
  transform: translateX(-50%)
}
.dora-slider__handle--last {
  z-index: 2
}
.dora-slider__handle--is-touched {
  transform: translate3d(-50%,-50%,0) scale(1.3)
}
.dora-slider--has-tip .dora-slider__handle--is-touched::after {
  display: block;
  opacity: 1;
  visibility: visible
}
.dora-slider__mark {
  width: 8rpx;
  height: 8rpx;
  position: absolute;
  border-radius: 50%;
  background-color: #bfbfbf;
  transform: translateX(-50%)
}
.dora-slider__max,
.dora-slider__min {
  font-size: 24rpx;
  color: var(--dora-color-text-secondary,#999);
  color: var(--dora-color-text-secondary,#999)
}
.dora-slider__min {
  margin-right: 16rpx
}
.dora-slider__max {
  margin-left: 16rpx
}
.dora-slider--disabled {
  opacity: .45
}
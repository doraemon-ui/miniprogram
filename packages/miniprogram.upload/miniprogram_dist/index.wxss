@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-upload {
  position: relative;
  display: block;
  overflow: hidden
}
.dora-upload--disabled {
  opacity: var(--dora-disabled-opacity,.3);
  opacity: var(--dora-disabled-opacity,.3);
  cursor: not-allowed
}
.dora-upload--picture-card .dora-upload__select {
  width: 156rpx;
  height: 156rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8rpx;
  margin: 0 16rpx 16rpx 0;
  background-color: #fafafa;
  transition: border-color .3s ease;
  box-sizing: border-box;
  float: left;
  cursor: pointer
}
.dora-upload--picture-card .dora-upload__button {
  width: 100%;
  height: 100%;
  display: -ms-flexbox;
  display: flex;
  text-align: center;
  -ms-flex-pack: center;
  justify-content: center;
  -ms-flex-align: center;
  align-items: center;
  padding: 8rpx;
  box-sizing: border-box
}
.dora-upload--picture-card .dora-upload__button image {
  width: 100%;
  height: 100%;
  display: inline-block;
  overflow: hidden
}
.dora-upload--picture-card .dora-upload__files {
  position: relative;
  display: block;
  float: left;
  overflow: hidden
}
.dora-upload--picture-card .dora-upload__file {
  width: 156rpx;
  height: 156rpx;
  float: left;
  margin: 0 16rpx 16rpx 0;
  padding: 8rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d9d9d9;
  position: relative;
  box-sizing: border-box;
  cursor: pointer
}
.dora-upload--picture-card .dora-upload__file--uploading {
  border-style: dashed
}
.dora-upload--picture-card .dora-upload__file--error {
  border-color: #ff4d4f
}
.dora-upload--picture-card .dora-upload__thumb {
  width: 100%;
  height: 100%;
  display: inline-block;
  overflow: hidden
}
.dora-upload--picture-card .dora-upload__remove {
  width: 32rpx;
  height: 32rpx;
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  border-radius: 50%;
  background: rgba(0,0,0,.45);
  cursor: pointer
}
<dora-list
  id="dora-list"
  dora-class="{{ prefixCls }}"
  prefixCls="{{ cellGroupPrefixCls }}"
  title="{{ title }}"
  label="{{ label }}"
  mode="{{ mode }}"
  bodyStyle="{{ bodyStyle }}"
  hasLine="{{ !hasFieldDecorator ? hasLine : false }}"
  wx:if="{{ withListComponent }}"
>
  <block
    wx:for="{{ showOptions }}"
    wx:for-item="option"
    wx:for-index="index"
    wx:key="__comp_unique_key"
    wx:if="{{ options.length > 0 }}"
  >
    <dora-radio
      class="{{ prefixCls + '__radio' }}"
      prefixCls="{{ option.prefixCls || 'dora-radio' }}"
      cellPrefixCls="{{ option.cellPrefixCls || 'dora-list-item' }}"
      selectablePrefixCls="{{ option.selectablePrefixCls || 'dora-selectable' }}"
      thumb="{{ option.thumb || '' }}"
      title="{{ option.title || '' }}"
      label="{{ option.label || '' }}"
      value="{{ option.value }}"
      checked="{{ inputValue === option.value }}"
      disabled="{{ option.disabled || disabled }}"
      readOnly="{{ option.readOnly || readOnly }}"
      color="{{ option.color || 'balanced' }}"
      data-index="{{ index }}"
      bind:change="onRadioChange"
    />
  </block>
  <block wx:if="{{ options.length === 0 }}">
    <slot></slot>
  </block>
</dora-list>
<block wx:else>
  <block
    wx:for="{{ showOptions }}"
    wx:for-item="option"
    wx:for-index="index"
    wx:key="__comp_unique_key"
    wx:if="{{ options.length > 0 }}"
  >
    <dora-radio
      class="{{ prefixCls + '__radio' }}"
      prefixCls="{{ option.prefixCls || 'dora-radio' }}"
      cellPrefixCls="{{ option.cellPrefixCls || 'dora-list-item' }}"
      selectablePrefixCls="{{ option.selectablePrefixCls || 'dora-selectable' }}"
      thumb="{{ option.thumb || '' }}"
      title="{{ option.title || '' }}"
      label="{{ option.label || '' }}"
      value="{{ option.value }}"
      checked="{{ inputValue === option.value }}"
      disabled="{{ option.disabled || disabled }}"
      readOnly="{{ option.readOnly || readOnly }}"
      color="{{ option.color || 'balanced' }}"
      data-index="{{ index }}"
      bind:change="onRadioChange"
    />
  </block>
  <block wx:if="{{ options.length === 0 }}">
    <slot></slot>
  </block>
</block>


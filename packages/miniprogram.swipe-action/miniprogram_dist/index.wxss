@import '../../@doraemon-ui/style/var.wxss';

@import '../../@doraemon-ui/style/color.wxss';

.dora-swipe {
  overflow: hidden;
  position: relative;
  cursor: grab
}
.dora-swipe__cover {
  position: absolute;
  z-index: 2;
  background: 0 0;
  height: 100%;
  width: 100%;
  top: 0
}
.dora-swipe__actions {
  position: absolute;
  top: 0;
  bottom: 0;
  display: -ms-flexbox;
  display: flex;
  overflow: hidden;
  white-space: nowrap;
  transition: all .25s
}
.dora-swipe__actions--left {
  left: 0
}
.dora-swipe__actions--right {
  right: 0
}
.dora-swipe__action {
  display: -ms-flexbox;
  display: flex;
  -ms-flex-align: center;
  align-items: center;
  -ms-flex-pack: center;
  justify-content: center;
  overflow: hidden;
  cursor: pointer
}
.dora-swipe__text {
  padding: 0 16rpx
}
.dora-swipe__content {
  position: relative;
  background-color: #fff;
  transition: all .25s
}
.dora-swipe--swiping .dora-swipe__actions,
.dora-swipe--swiping .dora-swipe__content {
  transition: none
}
.inline-wrap {
  padding: 24rpx;
  font-size: 32rpx;
}

.loadmore {
  display: inline-flex;
  align-items: center;
  font-weight: normal;
  font-size: 28rpx;
}

.loading {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  border: 4rpx solid #e9e9e9;
  border-top-color: #989697;
  border-radius: 50%;
  animation: loading 1s linear infinite;
}

.text {
  display: inline-block;
}

@keyframes loading {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}


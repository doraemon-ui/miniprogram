<demo-page title="DatePickerView" desc="日期选择器" spacing>
  <dora-segmented-control values="{{ ['zh_CN', 'zh_TW', 'en'] }}" bind:change="onChange" />
  <demo-block title="Default {{ displayValue1 }}">
    <dora-date-picker-view lang="{{ lang }}" value="{{ value1 }}" data-index="{{ 1 }}" bind:valueChange="onValueChange" />
  </demo-block>
  <demo-block title="Mode = date {{ displayValue2 }}">
    <dora-date-picker-view mode="date" lang="{{ lang }}" value="{{ value2 }}" data-index="{{ 2 }}" bind:valueChange="onValueChange" />
  </demo-block>
  <demo-block title="Mode = year {{ displayValue3 }}">
    <dora-date-picker-view mode="year" lang="{{ lang }}" value="{{ value3 }}" data-index="{{ 3 }}" bind:valueChange="onValueChange" />
  </demo-block>
  <demo-block title="Mode = month {{ displayValue4 }}">
    <dora-date-picker-view mode="month" lang="{{ lang }}" value="{{ value4 }}" data-index="{{ 4 }}" bind:valueChange="onValueChange" />
  </demo-block>
  <demo-block title="Mode = time {{ displayValue5 }}">
    <dora-date-picker-view mode="time" lang="{{ lang }}" value="{{ value5 }}" data-index="{{ 5 }}" bind:valueChange="onValueChange" />
  </demo-block>
  <demo-block title="Use12Hours & datetime {{ displayValue6 }}">
    <dora-date-picker-view use12Hours mode="datetime" lang="{{ lang }}" value="{{ value6 }}" data-index="{{ 6 }}" bind:valueChange="onValueChange" />
  </demo-block>
  <demo-block title="Use12Hours & time {{ displayValue7 }}">
    <dora-date-picker-view use12Hours mode="time" lang="{{ lang }}" value="{{ value7 }}" data-index="{{ 7 }}" bind:valueChange="onValueChange" />
  </demo-block>
  <demo-block title="TillNow {{ displayValue8 }}">
    <dora-date-picker-view tillNow lang="{{ lang }}" value="{{ value8 }}" data-index="{{ 8 }}" bind:valueChange="onValueChange" />
  </demo-block>
</demo-page>
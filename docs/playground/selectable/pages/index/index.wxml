<demo-page
  darkmode="auto"
  title="Selectable"
  desc="选框组"
  clickable
  spacing
>
  <demo-block title="Checkbox & Radio">
    <dora-selectable color="light" value="1" defaultChecked />
    <dora-selectable color="stable" value="2" defaultChecked />
    <dora-selectable color="positive" value="3" defaultChecked />
    <dora-selectable color="calm" value="4" />
    <dora-selectable color="balanced" value="5" />
    <dora-selectable color="energized" value="6" />
    <dora-selectable color="assertive" value="7" disabled />
    <dora-selectable color="royal" value="8" disabled />
    <dora-selectable color="dark" value="9" disabled />
    <dora-selectable type="radio" color="light" value="1" defaultChecked />
    <dora-selectable type="radio" color="stable" value="2" defaultChecked />
    <dora-selectable type="radio" color="positive" value="3" defaultChecked />
    <dora-selectable type="radio" color="calm" value="4" defaultChecked />
    <dora-selectable type="radio" color="balanced" value="5" defaultChecked />
    <dora-selectable type="radio" color="energized" value="6" defaultChecked />
    <dora-selectable type="radio" color="assertive" value="7" disabled defaultChecked />
    <dora-selectable type="radio" color="royal" value="8" disabled defaultChecked />
    <dora-selectable type="radio" color="dark" value="9" disabled defaultChecked />
  </demo-block>

  <demo-block title="Controlled">
    <dora-selectable color="light" value="1" checked="{{ checked }}" controlled bind:change="onCheckboxChange" />
  </demo-block>

  <demo-block title="Slot">
    <dora-selectable color="light" value="1" type="default">
      <view class="icon-on" slot="icon-on"></view>
      <view class="icon-off" slot="icon-off"></view>
    </dora-selectable>
  </demo-block>

  <demo-block title="Other">
    <dora-selectable color="light" value="1">Agree agreement</dora-selectable>
  </demo-block>
</demo-page>
<demo-page
  darkmode="auto"
  title="Card"
  desc="卡片"
  clickable
  spacing
>
  <demo-block title="Default">
    <dora-card title="卡片标题" extra="额外内容">
      <view slot="body">卡片内容</view>
      <view slot="footer">尾部内容</view>
    </dora-card>
  </demo-block>

  <demo-block title="Thumb">
    <dora-card title="卡片标题" extra="额外内容" thumb="http://cdn.skyvow.cn/logo.png">
      <view slot="body">卡片内容</view>
      <view slot="footer">尾部内容</view>
    </dora-card>
  </demo-block>

  <demo-block title="Custom thumb style">
    <dora-card
      title="卡片标题"
      extra="额外内容"
      thumb="http://cdn.skyvow.cn/logo.png"
      thumbStyle="border-radius: 50%;"
    >
      <view slot="body">卡片内容</view>
      <view slot="footer">尾部内容</view>
    </dora-card>
  </demo-block>

  <demo-block title="No border">
    <dora-card bordered="{{ false }}" title="卡片标题" extra="额外内容" thumb="http://cdn.skyvow.cn/logo.png">
      <view slot="body">卡片内容</view>
      <view slot="footer">尾部内容</view>
    </dora-card>
  </demo-block>

  <demo-block title="Full">
    <dora-card full title="卡片标题" extra="额外内容" thumb="http://cdn.skyvow.cn/logo.png">
      <view slot="body">卡片内容</view>
      <view slot="footer">尾部内容</view>
    </dora-card>
  </demo-block>

  <demo-block title="Actions">
    <dora-card full title="付款金额" extra="¥1024.00" actions="{{ actions }}" bind:action="onAction">
      <view slot="body">商品：电动打蛋机</view>
      <view slot="footer">状态：未支付</view>
    </dora-card>
  </demo-block>
</demo-page>
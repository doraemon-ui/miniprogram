{
  "name": "root",
  "private": true,
  "workspaces": {
    "packages": [
      "demos/*",
      "packages/*",
      "playground/*"
    ],
    "nohoist": [
      "**@doraemon-ui/style**"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-class-static-block": "^7.21.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-jest": "^30.3.0",
    "core-js": "^3.49.0",
    "docsify-cli": "^4.4.4",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "micromatch": "^4.0.8",
    "miniprogram-api-typings": "^5.1.2",
    "miniprogram-simulate": "^1.6.1",
    "pnpm": "^10.33.0",
    "postcss-less": "^6.0.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "^29.4.9",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "start:docs": "./node_modules/.bin/docsify serve docs -p 80",
    "build:docs": "node scripts/build-docs.js",
    "build:pkg-deps": "node scripts/build-pkg-deps.js",
    "prettier": "prettier --check \"{packages,playground,demos}/**/*.{js,ts,jsx,tsx,json,less,css,md}\"",
    "prettier:fix": "prettier --write \"{packages,playground,demos}/**/*.{js,ts,jsx,tsx,json,less,css,md}\"",
    "eslint": "eslint {packages,playground,demos}/** --ext js,ts",
    "eslint:fix": "eslint {packages,playground,demos}/** --ext js,ts --fix",
    "stylelint": "stylelint \"{packages,playground,demos}/**/*.less\" --syntax less",
    "stylelint:fix": "stylelint \"{packages,playground,demos}/**/*.less\" --syntax less --fix",
    "lint": "pnpm eslint && pnpm stylelint",
    "lint:fix": "pnpm eslint:fix && pnpm stylelint:fix",
    "pre-commit": "lint-staged",
    "changed": "lerna changed --include-merged-tags",
    "publish:alpha": "lerna publish prerelease --include-merged-tags --allow-branch '**' --pre-dist-tag alpha --preid alpha --force-git-tag",
    "publish:beta": "lerna publish prerelease --include-merged-tags --allow-branch '**' --pre-dist-tag beta --preid beta --force-git-tag",
    "publish:omega": "lerna publish prerelease --include-merged-tags --allow-branch '**' --pre-dist-tag omega --preid omega --force-git-tag",
    "release": "lerna publish --conventional-commits --conventional-graduate --include-merged-tags --changelog-preset angular",
    "preinstall": "npx only-allow pnpm",
    "test": "lerna run test --stream"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pnpm pre-commit"
    }
  },
  "packageManager": "pnpm@10.29.3"
}
